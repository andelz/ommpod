{
  "name": "pod",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --port 4711",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "i18n:extract": "ngx-translate-extract --input ./src --output ./public/i18n/en.json ./public/i18n/de.json --sort --clean --format json",
    "postinstall": "node -e \"require('fs').rmSync('node_modules/@colsen1991/ngx-translate-extract/node_modules/@angular', {recursive:true, force:true})\""
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^21.2.5",
    "@angular/compiler": "^21.2.5",
    "@angular/core": "^21.2.5",
    "@angular/forms": "^21.2.5",
    "@angular/platform-browser": "^21.2.5",
    "@angular/router": "^21.2.5",
    "@angular/service-worker": "^21.2.5",
    "@colsen1991/ngx-translate-extract-marker": "^3.0.1",
    "@inrupt/solid-client": "^3.0.0",
    "@inrupt/solid-client-authn-browser": "^3.1.1",
    "@inrupt/vocab-common-rdf": "^1.0.5",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "idb": "^8.0.3",
    "lucide-angular": "^0.577.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^21.2.5",
    "@colsen1991/ngx-translate-extract": "^8.0.8",
    "@types/jasmine": "~5.1.0",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.9.2"
  }
}
